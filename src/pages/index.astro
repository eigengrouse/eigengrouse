---
import Layout from '../layouts/Layout.astro';

const allPosts = Object.values(import.meta.glob('./posts/*.mdx', { eager: true }))
	.sort((a, b) =>
    	new Date(b.frontmatter.pubDate).getTime() -
    	new Date(a.frontmatter.pubDate).getTime()
	);
---

<Layout>
	<h4>My Retro Computing Blog</h4>
	<ul>
		{allPosts.map((post: any) => <li><a href={post.url}>{post.frontmatter.title} - {post.frontmatter.description}</a></li>)}
	</ul>
	<h4>My Links</h4>
	<ul>
		<li><a href="https://bsky.app/profile/eigengrouse.com">BlueSky</a></li>
		<li><a href="https://github.com/eigengrouse">GitHub</a></li>
	</ul>
</Layout>
